{
  "name": "administration-ga",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.2.17",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --concurrency=3",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "//dev-perf-note": "Cf. CLAUDE.md section 'Performance dev'. Machine 16 GB RAM : lancer max 2 apps en parallèle (chacune ~2.0 GB avec NODE_OPTIONS=--max-old-space-size=2048). Avant la 1re session, purger les caches via `bun clean:caches`. Préférer dev:eco quand QA croisée pas requise.",
    "clean:caches": "rm -rf apps/*/.next apps/*/.turbo packages/*/.turbo && echo '✓ Caches .next/ et .turbo/ purgés'",
    "clean:full": "bun clean:caches && rm -rf node_modules apps/*/node_modules packages/*/node_modules && echo '✓ Caches + node_modules purgés. Relancer bun install.'",
    "dev:eco": "turbo dev --concurrency=2 --filter=demarche.ga --filter=admin-gabon-backoffice",
    "dev:eco-pnpe": "turbo dev --concurrency=2 --filter=demarche.ga --filter=pnpe-gabon",
    "dev:eco-trio": "turbo dev --concurrency=3 --filter=demarche.ga --filter=admin-gabon-backoffice --filter=pnpe-gabon",
    "dev:users-web": "bun run dev --filter=users-web",
    "dev:demarche.ga": "bun run dev --filter=demarche.ga",
    "dev:administration.ga": "bun run dev --filter=administration.ga",
    "dev:admin.administration.ga": "bun run dev --filter=admin-gabon-backoffice",
    "dev:mairie.ga": "bun run dev --filter=mairie-gabon",
    "dev:direction.ga": "bun run dev --filter=direction-gabon",
    "dev:ministere.ga": "bun run dev --filter=ministere-gabon",
    "dev:pnpe.ga": "bun run dev --filter=pnpe-gabon",
    "dev:convex": "bunx convex dev",
    "fix:convex-local": "bash scripts/fix-convex-local-ports.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/better-auth": "^0.11.4",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.3",
    "@google/genai": "^1.47.0",
    "@google/generative-ai": "^0.24.1",
    "@livekit/protocol": "^1.44.0",
    "@react-pdf/renderer": "^4.3.0",
    "@tiptap/core": "^3.17.1",
    "@tiptap/extension-bubble-menu": "^3.22.3",
    "@tiptap/extension-floating-menu": "^3.22.3",
    "@tiptap/html": "^3.17.1",
    "@types/web-push": "^3.6.4",
    "@workspace/document-rendering": "workspace:*",
    "better-auth": "~1.5.6",
    "browser-image-compression": "^2.0.2",
    "convex": "^1.34.1",
    "convex-helpers": "^0.1.114",
    "docx": "^9.6.1",
    "google-auth-library": "^10.6.2",
    "jszip": "^3.10.1",
    "livekit-server-sdk": "^2.15.0",
    "pdf-lib": "^1.17.1",
    "posthog-node": "^5.28.8",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "remove.bg": "^1.3.0",
    "resend": "^6.9.4",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.10",
    "esbuild": "0.27.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "qrcode": "^1.5.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "form-data": ">=2.5.4"
  }
}
