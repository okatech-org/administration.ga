{
  "extends": "@workspace/tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": false,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@convex/*": ["../../convex/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/api/*": ["../../packages/api/src/*"],
      "@workspace/i18n/*": ["../../packages/i18n/src/*"],
      "@workspace/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
