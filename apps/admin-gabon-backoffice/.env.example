# ──────────────────────────────────────────────────────────────────────────
# BACKOFFICE-WEB — ADMINISTRATION.GA (super-admin national)
# Port dev : 3002
# Domaine prod : admin.administration.ga
# ──────────────────────────────────────────────────────────────────────────

# ── Identité de l'application ──
NEXT_PUBLIC_APP_NAME=ADMINISTRATION.GA
NEXT_PUBLIC_DOMAIN_CITIZEN=demarche.ga
NEXT_PUBLIC_DOMAIN_AGENT=administration.ga
NEXT_PUBLIC_DOMAIN_ADMIN=admin.administration.ga

# ── Convex ──
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site

# ── URLs et auth ──
NEXT_PUBLIC_SITE_URL=http://localhost:3002
BETTER_AUTH_SECRET=replace_with_generated_secret

# ── Mapbox ──
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── PostHog analytics (laisser vide en dev) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Push notifications Web ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Feature flags ──
NEXT_PUBLIC_FEATURE_CALL_CENTER=0
NEXT_PUBLIC_FEATURE_EGRESS=0
NEXT_PUBLIC_FEATURE_PUSH=0
NEXT_PUBLIC_FEATURE_SUPERVISION_WHISPER=1

# ── Debug ──
NEXT_PUBLIC_DEBUG_CALLS=0
NEXT_PUBLIC_E2E_MODE=false
