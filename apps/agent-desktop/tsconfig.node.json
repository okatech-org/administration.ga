{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@workspace/desktop-shared/*": ["../../packages/desktop-shared/src/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "electron.vite.config.ts"
  ]
}
