# ──────────────────────────────────────────────────────────────────────────
# PNPE — Pôle National de Promotion de l'Emploi (héritier de l'ONE)
# Tutelle : Ministère du Travail, du Plein Emploi, du Dialogue Social
#           et de la Formation Professionnelle
# Port dev : 3008
# Domaine prod : emploi.administration.ga
# ──────────────────────────────────────────────────────────────────────────

# ── Identité de l'application ──
NEXT_PUBLIC_APP_NAME=PNPE
NEXT_PUBLIC_DOMAIN_CITIZEN=demarche.ga
NEXT_PUBLIC_DOMAIN_AGENT=administration.ga
NEXT_PUBLIC_DOMAIN_ADMIN=admin.administration.ga
NEXT_PUBLIC_DOMAIN_EMPLOI=emploi.administration.ga

# ── Convex (backend partagé du monorepo administration.ga) ──
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site

# ── URLs et auth ──
NEXT_PUBLIC_SITE_URL=http://localhost:3008
BETTER_AUTH_SECRET=replace_with_generated_secret

# ── Mapbox (cartes territoriales, géolocalisation antennes) ──
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── PostHog analytics (laisser vide en dev) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Push notifications Web ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Feature flags ──
NEXT_PUBLIC_FEATURE_CALL_CENTER=1
NEXT_PUBLIC_FEATURE_EGRESS=0
NEXT_PUBLIC_FEATURE_PUSH=0
NEXT_PUBLIC_FEATURE_SUPERVISION_WHISPER=1
NEXT_PUBLIC_VOICE_PROVIDER=livekit

# ── Debug ──
NEXT_PUBLIC_DEBUG_CALLS=0
NEXT_PUBLIC_E2E_MODE=false

# ── Dev accounts (sélecteur de comptes de développement) ──
NEXT_PUBLIC_DEV_ACCOUNTS=[]

# ──────────────────────────────────────────────────────────────────────────
# INTÉGRATIONS PNPE (Phase 7) — configurer côté Convex (npx convex env set)
# ──────────────────────────────────────────────────────────────────────────

# Resend (emails transactionnels D.E / employeurs)
# RESEND_API_KEY=

# Twilio (SMS + WhatsApp Business pour validation D.E)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+24107000000

# DGI (Direction Générale des Impôts) — vérification fiscale employeurs
# DGI_API_BASE=
# DGI_API_KEY=

# CNSS (Caisse Nationale de Sécurité Sociale) — attestation sociale
# CNSS_API_BASE=
# CNSS_API_KEY=

# Ediandza (formation professionnelle) — SSO ou redirection paramétrée
# EDIANDZA_PARTNER_ID=

# ANPI-Gabon (formalisation auto-emploi) — webhook de retour
# ANPI_GABON_PARTNER_ID=

# Mode mock intégrations externes (dev/staging) — 1 active, vide désactive
# PNPE_MOCK_INTEGRATIONS=1
